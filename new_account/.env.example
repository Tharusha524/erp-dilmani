# Copy to .env and restart npm run dev after any change

# Base path the app is served under (Vite `base` + React Router basename).
# No leading/trailing slash needed — e.g. "sky_erp" or "dilamani_apparel".
VITE_APP_BASE_PATH=sky_erp

VITE_API_BASE_URL=https://finance.skytechsl.com/sky_erp/backend/public/index.php/api

# Origin used to build APP_PUBLIC_URL (rarely needed directly).
VITE_APP_PUBLIC_ORIGIN=https://finance.skytechsl.com

# Test API: npm run verify:api
# Build:    npm run build  → upload dist/* to public_html/<VITE_APP_BASE_PATH>/

# Local Laravel (php artisan serve + vite proxy):
# VITE_APP_BASE_PATH=
# VITE_API_BASE_URL=/api
# VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# Backend .env (Laravel on server) should include:
# APP_URL=https://<your-domain>/<base-path>/backend/public
# SANCTUM_STATEFUL_DOMAINS=<your-domain>
# FRONTEND_URL=https://<your-domain>/<base-path>
