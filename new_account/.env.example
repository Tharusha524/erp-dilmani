# Copy to .env and restart npm run dev after any change
VITE_API_BASE_URL=https://finance.skytechsl.com/sky_erp/backend/public/index.php/api

# Frontend (Vite base + React Router): /sky_erp/
# Live app:  https://finance.skytechsl.com/sky_erp/
# Backend:   https://finance.skytechsl.com/sky_erp/backend/public/

# Test API: npm run verify:api
# Build:    npm run build  → upload dist/* to public_html/sky_erp/

# Local Laravel (php artisan serve + vite proxy):
# VITE_API_BASE_URL=/api
# VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# Backend .env (Laravel on server) should include:
# APP_URL=https://finance.skytechsl.com/sky_erp/backend/public
# SANCTUM_STATEFUL_DOMAINS=finance.skytechsl.com
# FRONTEND_URL=https://finance.skytechsl.com/sky_erp
