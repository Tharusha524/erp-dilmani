# =============================================================================
# ERP Production Environment — copy to .env on the server
# =============================================================================

APP_NAME="Grow Ledger"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-domain.com/your-base-path/backend/public

# --- Frontend / CORS (must match your deployed frontend origin) ---
SANCTUM_STATEFUL_DOMAINS=your-domain.com
FRONTEND_URL=https://your-domain.com/your-base-path

LOG_CHANNEL=stack
LOG_LEVEL=error

# --- Database ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=backend
DB_USERNAME=erp_user
DB_PASSWORD=change-me-strong-password

# --- Performance: Redis (recommended for production) ---
CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Dashboard cache (seconds) ---
DASHBOARD_CACHE_SECONDS=300
DASHBOARD_ALERTS_CACHE_SECONDS=120

# --- API pagination defaults ---
API_DEFAULT_PER_PAGE=50
API_MAX_PER_PAGE=200

# --- Security ---
SANCTUM_TOKEN_EXPIRATION=480
LOGIN_RATE_LIMIT=5
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

BCRYPT_ROUNDS=12
