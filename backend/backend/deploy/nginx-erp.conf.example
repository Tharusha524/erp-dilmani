# Nginx site config for Grow Ledger ERP (Linux).
# Copy to: /etc/nginx/sites-available/erp  then enable + reload nginx.

server {
    listen 80;
    server_name your-domain.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name your-domain.com;

    root /var/www/erp/backend/public;
    index index.php;

    ssl_certificate     /etc/ssl/certs/your-domain.crt;
    ssl_certificate_key /etc/ssl/private/your-domain.key;

    client_max_body_size 32M;
    gzip on;
    gzip_types application/json text/css application/javascript;

    # React SPA (built frontend)
    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }

    location ~ \.php$ {
        fastcgi_pass unix:/run/php/php8.2-fpm.sock;
        fastcgi_param SCRIPT_FILENAME $realpath_root$fastcgi_script_name;
        include fastcgi_params;
        fastcgi_read_timeout 120;
    }

    location ~ /\.(?!well-known).* {
        deny all;
    }
}

# Optional: serve React build from separate root
# server {
#     listen 443 ssl http2;
#     server_name app.your-domain.com;
#     root /var/www/erp/new_account/dist;
#     try_files $uri $uri/ /index.html;
# }
