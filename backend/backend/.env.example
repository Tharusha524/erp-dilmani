APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=backend
DB_USERNAME=root
DB_PASSWORD=1234

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# Redis-first production recommendation for ERP workloads:
# CACHE_STORE=redis
# QUEUE_CONNECTION=redis
# SESSION_DRIVER=redis
# SESSION_CONNECTION=default
# REDIS_QUEUE=default

# --- Performance (production) ---
# APP_DEBUG=false
# APP_ENV=production
# LOG_LEVEL=error
DASHBOARD_CACHE_SECONDS=300
DASHBOARD_ALERTS_CACHE_SECONDS=120
API_DEFAULT_PER_PAGE=50
API_MAX_PER_PAGE=200

# See deploy/PERFORMANCE.md, deploy/CYBERPANEL.md and deploy/production.env.example

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# AI Agent — any OpenAI-compatible API (see free options below)
AI_ENABLED=false
AI_API_KEY=

# --- Option A (recommended free): Google Gemini (native API) ---
# 1. Go to https://aistudio.google.com/apikey
# 2. Create API key (AIzaSy... recommended; OAuth tokens also work)
# AI_PROVIDER=gemini
# AI_API_URL=https://generativelanguage.googleapis.com/v1beta
# AI_MODEL=gemini-2.5-flash
# AI_FALLBACK_MODELS=gemini-2.5-flash-lite,gemini-2.0-flash

# --- Option B (free): Groq — fast, free tier ---
# 1. Sign up at https://console.groq.com
# 2. Keys → Create API Key
# AI_API_URL=https://api.groq.com/openai/v1
# AI_MODEL=llama-3.3-70b-versatile

# --- Option C (100% free, offline): Ollama on your PC ---
# 1. Install from https://ollama.com
# 2. Run: ollama pull llama3.2
# 3. Ollama serves OpenAI API at localhost
# AI_API_URL=http://127.0.0.1:11434/v1
# AI_MODEL=llama3.2
# AI_API_KEY=ollama

# --- Option D (paid): OpenAI ---
# AI_API_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini

AI_PROVIDER=gemini
AI_API_URL=https://generativelanguage.googleapis.com/v1beta
AI_MODEL=gemini-2.5-flash
AI_FALLBACK_MODELS=gemini-2.5-flash-lite,gemini-2.0-flash
AI_MAX_TOKENS=1200
AI_TIMEOUT=60
AI_WHISPER_MODEL=whisper-large-v3

# Security (production recommended values shown in comments)
SANCTUM_TOKEN_EXPIRATION=480
LOGIN_RATE_LIMIT=5
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
AUTH_MAX_TOKENS_PER_USER=10
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_LETTER=true
PASSWORD_REQUIRE_NUMBER=true
# APP_DEBUG=false
# APP_ENV=production
